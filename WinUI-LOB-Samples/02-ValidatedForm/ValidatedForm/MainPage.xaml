<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ValidatedForm.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ValidatedForm"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="New Customer" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock
                Text="Fields marked required must be completed before saving."
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="480" HorizontalAlignment="Left" Spacing="16">

                <!--  Name (required)  -->
                <StackPanel Spacing="4">
                    <TextBox
                        x:Name="NameTextBox"
                        AutomationProperties.AutomationId="NameTextBox"
                        Header="Name (required)"
                        PlaceholderText="e.g. Ada Lovelace"
                        Text="{x:Bind ViewModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        AutomationProperties.AutomationId="NameError"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        Text="{x:Bind ViewModel.NameError, Mode=OneWay}"
                        Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.HasNameError), Mode=OneWay}" />
                </StackPanel>

                <!--  Email (required, valid format)  -->
                <StackPanel Spacing="4">
                    <TextBox
                        x:Name="EmailTextBox"
                        AutomationProperties.AutomationId="EmailTextBox"
                        Header="Email (required)"
                        PlaceholderText="e.g. ada@example.com"
                        Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        AutomationProperties.AutomationId="EmailError"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        Text="{x:Bind ViewModel.EmailError, Mode=OneWay}"
                        Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.HasEmailError), Mode=OneWay}" />
                </StackPanel>

                <!--  Phone (optional)  -->
                <StackPanel Spacing="4">
                    <TextBox
                        x:Name="PhoneTextBox"
                        AutomationProperties.AutomationId="PhoneTextBox"
                        Header="Phone (optional)"
                        PlaceholderText="e.g. (555) 123-4567"
                        Text="{x:Bind ViewModel.Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!--  Region (required)  -->
                <StackPanel Spacing="4">
                    <ComboBox
                        x:Name="RegionComboBox"
                        AutomationProperties.AutomationId="RegionComboBox"
                        Header="Region (required)"
                        HorizontalAlignment="Stretch"
                        PlaceholderText="Select a region"
                        ItemsSource="{x:Bind ViewModel.Regions}"
                        SelectedItem="{x:Bind ViewModel.Region, Mode=TwoWay}" />
                    <TextBlock
                        AutomationProperties.AutomationId="RegionError"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        Text="{x:Bind ViewModel.RegionError, Mode=OneWay}"
                        Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.HasRegionError), Mode=OneWay}" />
                </StackPanel>

                <Button
                    x:Name="SaveButton"
                    AutomationProperties.AutomationId="SaveButton"
                    Content="Save"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.SaveCommand}" />

                <InfoBar
                    x:Name="SavedInfoBar"
                    AutomationProperties.AutomationId="SavedInfoBar"
                    Severity="Success"
                    Title="Saved"
                    Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    IsOpen="{x:Bind ViewModel.IsStatusOpen, Mode=TwoWay}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
